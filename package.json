  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.12.3",
    "tslib": "^2.6.0",
    "typescript": "^5.9.3"
  }
